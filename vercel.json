{
  "buildCommand": "pnpm --filter @workspace/rk-associates run build",
  "outputDirectory": "artifacts/rk-associates/dist/public",
  "installCommand": "pnpm install",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://rk-associates-api.vercel.app/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}